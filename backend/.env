# ── Banco de Dados ────────────────────────────────────────────────
# Cole aqui a URL que o Railway gerar automaticamente
DATABASE_URL=postgresql://usuario:senha@host:5432/railway

# ── Servidor ──────────────────────────────────────────────────────
PORT=3001

# ── Segurança ─────────────────────────────────────────────────────
# Mude para uma string longa e aleatória
JWT_SECRET=troque_isso_por_uma_senha_super_secreta_123

# ── Admin ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=pizzaria123

# ── Frontend (URL do seu site na Vercel) ──────────────────────────
FRONTEND_URL=https://seu-site.vercel.app
